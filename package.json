{
  "name": "@dipras/nodamin",
  "version": "1.2.5",
  "description": "Lightweight Database Admin for Node.js",
  "keywords": [
    "database",
    "database-admin",
    "db-admin",
    "mysql",
    "mysql-admin",
    "mysql-gui",
    "mysql-web",
    "sqlite",
    "sqlite-admin",
    "nodejs",
    "node",
    "sql",
    "web-admin",
    "admin-panel",
    "database-manager",
    "multi-database",
    "db-gui"
  ],
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/dipras/nodamin#readme",
  "bugs": {
    "url": "https://github.com/dipras/nodamin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dipras/nodamin.git"
  },
  "license": "GPL-2.0-only",
  "author": "Dipras",
  "type": "module",
  "main": "dist/nodamin.js",
  "bin": {
    "nodamin": "dist/nodamin.js"
  },
  "scripts": {
    "build:templates": "node build-templates.js",
    "build:assets": "node build-assets.js",
    "build": "npm run build:templates && npm run build:assets && node esbuild.config.js",
    "start": "node dist/nodamin.js",
    "dev": "npm run build:templates && npm run build:assets && tsc --noEmit --watch & node --watch-path=src esbuild.config.js --dev",
    "typecheck": "npm run build:templates && npm run build:assets && tsc --noEmit"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "better-sqlite3": "^12.6.2",
    "formidable": "^3.5.4",
    "mysql2": "^3.18.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/formidable": "^3.4.7",
    "ejs": "^4.0.1",
    "esbuild": "^0.27.3"
  }
}