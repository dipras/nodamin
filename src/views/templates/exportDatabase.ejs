<h1>📦 Export Database: <%= data.database %></h1>
<div class="actions">
  <a href="/db/<%= encodeURIComponent(data.database) %>" class="btn">← Back to Database</a>
</div>

<div class="card">
  <h2>Export Options</h2>
  <p style="color: var(--text2); font-size: 13px; margin-bottom: 16px;">
    Choose export type and action
  </p>
  
  <form id="exportForm" style="display: flex; flex-direction: column; gap: 16px;">
    <div style="display: flex; gap: 24px; align-items: center;">
      <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
        <input type="radio" name="exportType" value="full" checked style="width: auto; height: 18px;" />
        <span>Full Data (Structure + Data)</span>
      </label>
      <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
        <input type="radio" name="exportType" value="structure" style="width: auto; height: 18px;" />
        <span>Structure Only</span>
      </label>
    </div>

    <div style="display: flex; gap: 12px; margin-top: 8px;">
      <button type="button" class="btn btn-primary" onclick="downloadExport()">💾 Download</button>
      <button type="button" class="btn" onclick="openPreview()">👁️ Open Preview</button>
    </div>
  </form>
</div>

<% if (data.preview) { %>
<div class="card" style="margin-top: 16px;">
  <h2>SQL Preview</h2>
  <p style="color: var(--text2); font-size: 13px; margin-bottom: 12px;">
    Preview of the export. Copy or download the SQL dump.
  </p>
  <textarea readonly style="width: 100%; min-height: 400px; font-family: 'Cascadia Code', 'Fira Code', monospace; font-size: 12px;"><%= data.dump %></textarea>
  <div style="margin-top: 12px;">
    <button class="btn btn-primary" onclick="copyDump()">📋 Copy to Clipboard</button>
  </div>
</div>

<script>
function copyDump() {
  const textarea = document.querySelector('textarea');
  textarea.select();
  document.execCommand('copy');
  alert('SQL dump copied to clipboard!');
}
</script>
<% } %>

<script>
function downloadExport() {
  const exportType = document.querySelector('input[name="exportType"]:checked').value;
  const structureOnly = exportType === 'structure' ? '1' : '0';
  window.location.href = '/db/<%= encodeURIComponent(data.database) %>/export?download=1&structureOnly=' + structureOnly;
}

function openPreview() {
  const exportType = document.querySelector('input[name="exportType"]:checked').value;
  const structureOnly = exportType === 'structure' ? '1' : '0';
  window.location.href = '/db/<%= encodeURIComponent(data.database) %>/export?open=1&structureOnly=' + structureOnly;
}
</script>
