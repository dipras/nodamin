<h1>📝 SQL Query<% if (data.database) { %> — <%= data.database %><% } %></h1>
<div class="actions">
  <a href="<%= data.database ? '/db/' + encodeURIComponent(data.database) : '/' %>" class="btn">← Back</a>
</div>
<div class="card sql-editor">
  <form method="POST" action="<%= data.database ? '/db/' + encodeURIComponent(data.database) + '/sql' : '/sql' %>">
    <div class="form-group">
      <label>SQL Statement</label>
      <textarea name="sql" style="width:100%;min-height:160px;" placeholder="SELECT * FROM ..."><%= data.sql || '' %></textarea>
    </div>
    <button type="submit" class="btn btn-primary">▶ Execute</button>
  </form>
</div>
<% if (data.result) { %>
  <% if (data.result.message) { 
    const isError = data.result.message.startsWith('Error:');
  %>
    <div class="msg <%= isError ? 'msg-error' : 'msg-success' %>"><%= data.result.message %></div>
  <% } %>
  <% if (data.result.rows.length > 0) { 
    const fields = data.result.fields.map(f => f.name);
  %>
    <div class="card" style="padding:0;overflow:hidden;margin-top:16px;">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <% fields.forEach(function(f) { %>
                <th><%= f %></th>
              <% }); %>
            </tr>
          </thead>
          <tbody>
            <% data.result.rows.forEach(function(row) { %>
              <tr>
                <% fields.forEach(function(f) { %>
                  <td><% if (row[f] === null) { %><span class="null">NULL</span><% } else { %><%= String(row[f]) %><% } %></td>
                <% }); %>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="info" style="margin-top:8px;font-size:12px;color:var(--text2);"><%= data.result.rows.length %> row(s) returned</div>
  <% } %>
<% } %>
