<h1>🗄️ <%= data.database %></h1>
<% if (data.message) { %>
  <div class="msg msg-success"><%= data.message %></div>
<% } %>
<div class="actions">
  <a href="/" class="btn">← Databases</a>
  <a href="/db/<%= encodeURIComponent(data.database) %>/table/create" class="btn btn-primary">+ Create Table</a>
  <a href="/db/<%= encodeURIComponent(data.database) %>/import" class="btn">📥 Import SQL</a>
  <a href="/db/<%= encodeURIComponent(data.database) %>/sql" class="btn">📝 SQL Query</a>
</div>
<% if (data.tables.length === 0) { %>
  <div class="empty">No tables found in this database</div>
<% } else { %>
  <div class="card" style="padding:0;overflow:hidden;">
    <table>
      <thead>
        <tr>
          <th>Table</th>
          <th>Engine</th>
          <th>Rows</th>
          <th>Size</th>
          <th>Collation</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% data.tables.forEach(function(t) { %>
          <tr>
            <td><a href="/db/<%= encodeURIComponent(data.database) %>/table/<%= encodeURIComponent(t.name) %>"><%= t.name %></a></td>
            <td><%= t.engine %></td>
            <td><%= t.rows.toLocaleString() %></td>
            <td><%= t.size %></td>
            <td><code><%= t.collation %></code></td>
            <td>
              <div style="display:flex;gap:4px;">
                <a href="/db/<%= encodeURIComponent(data.database) %>/table/<%= encodeURIComponent(t.name) %>/structure" class="btn btn-sm">Structure</a>
                <button class="btn btn-sm btn-danger" onclick="confirmAction('Drop table <%= t.name %>?', '/db/<%= encodeURIComponent(data.database) %>/table/<%= encodeURIComponent(t.name) %>/drop')">Drop</button>
                <button class="btn btn-sm" onclick="confirmAction('Truncate table <%= t.name %>?', '/db/<%= encodeURIComponent(data.database) %>/table/<%= encodeURIComponent(t.name) %>/truncate')" style="color:var(--warning);">Truncate</button>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>
